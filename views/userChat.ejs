<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Bootstrap demo</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"
        integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p"
        crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"
        integrity="sha384-cVKIPhGWiC2Al4u+LWgxfKTRIcfu0JTxR+EQDz/bgldoEyl4H0zUF0QKbrJ0EcQF"
        crossorigin="anonymous"></script>
    <!-- this for charts sidebar -->
    <script src="https://cdn.jsdelivr.net/npm/echarts@6.0.0/dist/echarts.min.js"></script>

</head>

<body class="bg-light">
    <div id="main" class="container rounded pt-3 d-flex flex-row">
        <div class="container" id="sidebar">
            <!-- sidebar by canvas -->
            <button id="btnside" class="btn btn-outline-secondary" type="button" data-bs-toggle="offcanvas"
                data-bs-target="#staticBackdrop" aria-controls="staticBackdrop">
                <i class="bi bi-list"></i>
            </button>

            <div class="offcanvas offcanvas-start" data-bs-backdrop="false" tabindex="-1" id="staticBackdrop"
                aria-labelledby="staticBackdropLabel">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="staticBackdropLabel">Give data access this tools</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body">

                    <form class="row g-3" method="post" action="/upload" enctype="multipart/form-data" >
                        <div class="col-12">
                            <label for="inputAddress" class="form-label">Google Sheet Id</label>
                            <input type="text" class="form-control" id="inputAddress" placeholder="1234 Main St"
                                name="googleSheetId" required>
                        </div>
                        <div class="col-12">
                            <label for="inputAddress2" class="form-label">Gemini AI api key</label>
                            <input type="text" class="form-control" id="inputAddress2"
                                placeholder="ex.fgavdufyafvdagfadfgad" name="geminiApiKey" required>
                        </div>
                        <div class="col-12">
                            <label for="inputState" class="form-label">Gemini Model</label>
                            <select class="form-select form-select-sm" name="model" aria-label="Small select example">
                                <option selected>Open this select menu</option>
                                <option value="gemini-2.5-flash">gemini-2.5-flash</option>
                                <option value="2">Two</option>
                                <option value="3">Three</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="formFileSm" class="form-label">Give credentials.json file from google from
                                    sheet </label>
                                <input class="form-control form-control-sm" id="formFileSm" type="file"
                                    name="uploaded_file" required>
                            </div>
                        </div>
                        <div class="col-12">
                            <button type="submit" id="submitBtn" class="btn btn-primary">Submit</button>
                            <button  type="submit" class="btn btn-primary">Remove</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- chart div -->
            <button id="btnside" class="btn btn-outline-secondary mt-5" data-bs-target="#exampleModalToggle"
                data-bs-toggle="modal">
                <i class="bi bi-bar-chart-line"></i></button>

            <div class="modal fade" id="exampleModalToggle" aria-hidden="true" aria-labelledby="exampleModalToggleLabel"
                tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content" id="showCharts">
                        <div class="modal-header">
                            <h1 class="modal-title fs-5" id="exampleModalToggleLabel">Charts</h1>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>

                        </div>
                        <div class="modal-body">
                            <select id="chartSelect" class="form-select form-select-lg mb-3"
                                aria-label="Large select example">
                                <option selected>Select charts</option>
                                <option value="waterfall">Waterfall Bar</option>
                                <option value="basicbar">Basic Bar</option>
                                <option value="piebar">Pie Chart</option>
                                <option value="multibar">Multi Bar</option>
                            </select>
                            <button class="btn btn-primary mb-3" id="btnCharts">Create Chart</button>
                            <!-- put charts here     -->
                            <div>
                                <h1 id="heading"></h1>
                                <div class="chart" style="width: 300px; height: 300px;"></div>
                            </div>
                        </div>
                        <div class="modal-footer">
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>
    <!-- Ai chat -->
    <div class="container bg-white rounded pt-3" id="body">
        <div class="input-group mb-3" id="input">
            <input id="prompt" type="text" class="form-control" placeholder="Ask something..."
                aria-label="Recipient's username with two button addons">
            <button class="btn btn-outline-secondary" onclick="askAI()" type="button" id="button">Send</button>
        </div>
    </div>

    <!-- All the scripte file there -->
    <script src="./js/chatfromuser.js" type="text/javascript"></script>
    <script src="./js/Charts.js" type="text/javascript"></script>

    <script src="./js/fromdata.js" type="text/javascript"></script>
</body>

</html>